SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=11520
ALGORITHM=HS256

# Wechat
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_REDIRECT_URI=

# SMS Service
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=

# API keys
API_KEYS=your-api-keys

# Limits
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# MySQL Config
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=job
MYSQL_CHARSET=utf8mb4

MYSQL_POOL_MIN_SIZE=5
MYSQL_POOL_MAX_SIZE=20
MYSQL_POOL_RECYCLE=3600
MYSQL_POOL_PRE_PING=true
MYSQL_POOL_ECHO=false

MYSQL_CONNECT_TIMEOUT=10
MYSQL_READ_TIMEOUT=30
MYSQL_WRITE_TIMEOUT=30

MYSQL_AUTOCOMMIT=true
MYSQL_AUTOFLUSH=true
MYSQL_EXPIRE_ON_COMMIT=false

# Postgres Config
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_DB=job
POSTGRES_POOL_MIN_SIZE=10
POSTGRES_POOL_MAX_SIZE=40

# Redis Config
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_MAX_CONNECTIONS=20
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_RETRY_ON_TIMEOUT=true
REDIS_HEALTH_CHECK_INTERVAL=30
REDIS_PASSWORD=

REDIS_KEY_PREFIX=job

# Scrapy Redis Config
SCRAPY_REDIS_URL=redis://localhost:6379/1
SCRAPY_REDIS_DUPEFILTER_DB=1
SCRAPY_REDIS_QUEUE_DB=1
SCRAPY_REDIS_PIPELINE_DB=1

# App Config
DEBUG=false
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# Elastic Search
ES_HOST=127.0.0.1
ES_PORT=9200
ES_USER=elastic
ES_PASSWORD=your_password
ES_INDEX_JOB=jobs

# AI
AI_PROVIDER=deepseek
AI_BASE_URL=https://api.deepseek.com
AI_API_KEY=your-api-key
AI_MODEL=deepseek-chat
